---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import { SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Contact — ${SITE_TITLE}`} description="Get in touch with Zuzi Knaze, interior creator based in The Hague." />
  </head>
  <body>
    <Header />
    <main class="px-5 pt-20 pb-[3.25rem] min-h-screen sm:px-6 sm:pt-[5.625rem] sm:pb-[3.75rem] lg:px-10 lg:pt-24 lg:pb-20">
      <div class="max-w-[38.75rem] mx-auto mt-8">
        <span class="block text-[0.8125rem] tracking-[0.1em] uppercase text-muted mb-5">Contact</span>
        <p class="text-sm leading-[1.9] text-prose mb-7">Zuzi Knaze is an interior creator based in The Hague, working at the intersection of architecture, spatial design, and everyday life.</p>
        <p class="text-sm leading-[1.9] text-prose mb-7">Every project starts with careful listening — to the space, to the people who inhabit it, and to the light that moves through it. The result is always honest and personal: spaces that feel both considered and lived-in, where beauty grows from function rather than sitting on top of it.</p>
        <p class="text-sm leading-[1.9] text-prose mb-7">Zuzi works on residential and small commercial projects, from full renovations to custom furniture and focused consultations. Sustainability and natural materials guide each decision — not as a trend, but as a way of thinking.</p>
        <p class="text-sm leading-[1.9] text-prose mb-7">Every commission is an opportunity to create something creative, meaningful, and lasting.</p>
        <div class="mt-12">
          <h3 class="font-medium text-sm mb-2">Zuzi Knaze</h3>
          <a href="mailto:zuzana.knazeova@gmail.com" class="text-sm text-muted block leading-[1.9] hover:text-black transition-colors duration-200">zuzana.knazeova@gmail.com</a>
          <span class="text-sm text-muted block leading-[1.9]">The Hague, Netherlands</span>
          <span class="text-xs text-faint block mt-2">Available for projects in the Netherlands and beyond.</span>
        </div>
      </div>
    </main>
  </body>
</html>
