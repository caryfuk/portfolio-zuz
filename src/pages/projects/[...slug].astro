---
import { type CollectionEntry, getCollection } from 'astro:content';
import Project from '../../layouts/Project.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  const sorted = projects.sort((a, b) => a.data.order - b.data.order);

  return sorted.map((project, i) => {
    const prev = i > 0 ? sorted[i - 1] : sorted[sorted.length - 1];
    const next = i < sorted.length - 1 ? sorted[i + 1] : sorted[0];

    return {
      params: { slug: project.slug },
      props: {
        project,
        prevSlug: prev.slug,
        prevImageCount: prev.data.images.length,
        nextSlug: next.slug,
      },
    };
  });
}

type Props = {
  project: CollectionEntry<'projects'>;
  prevSlug: string;
  prevImageCount: number;
  nextSlug: string;
};

const { project, prevSlug, prevImageCount, nextSlug } = Astro.props;
const { Content } = await project.render();
---

<Project {...project} Content={Content} prevSlug={prevSlug} prevImageCount={prevImageCount} nextSlug={nextSlug} />
