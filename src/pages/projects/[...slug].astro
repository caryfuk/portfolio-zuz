---
import { type CollectionEntry, getCollection } from "astro:content";
import path from "node:path";
import sharp from "sharp";
import Project from "../../layouts/Project.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  const yearKey = (p: typeof projects[number]) =>
    Number(p.data.year?.match(/\d{4}/g)?.pop() ?? 0);
  const sorted = projects.sort((a, b) => yearKey(b) - yearKey(a));

  return await Promise.all(
    sorted.map(async (project, i) => {
      const prev = i > 0 ? sorted[i - 1] : sorted[sorted.length - 1];
      const next = i < sorted.length - 1 ? sorted[i + 1] : sorted[0];

      let firstImageAR = 1;
      const firstImg = project.data.images[0];
      if (firstImg) {
        const imgPath = path.join(
          process.cwd(),
          "public",
          "projects",
          project.slug,
          `${firstImg.url}.jpg`
        );
        try {
          const meta = await sharp(imgPath).metadata();
          if (meta.width && meta.height) firstImageAR = meta.width / meta.height;
        } catch {}
      }

      return {
        params: { slug: project.slug },
        props: {
          project,
          prevSlug: prev.slug,
          prevImageCount: prev.data.images.length,
          nextSlug: next.slug,
          firstImageAR,
        },
      };
    })
  );
}

type Props = {
  project: CollectionEntry<"projects">;
  prevSlug: string;
  prevImageCount: number;
  nextSlug: string;
  firstImageAR: number;
};

const { project, prevSlug, prevImageCount, nextSlug, firstImageAR } = Astro.props;
const { Content } = await project.render();
---

<Project {...project} Content={Content} prevSlug={prevSlug} prevImageCount={prevImageCount} nextSlug={nextSlug} firstImageAR={firstImageAR} />
