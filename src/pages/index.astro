---
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

const allProjects = await getCollection("projects");
type Project = typeof allProjects[number];
const yearKey = (p: Project) =>
  Number(p.data.year?.match(/\d{4}/g)?.pop() ?? 0);
const sorted = allProjects.sort((a, b) => yearKey(b) - yearKey(a));

type Tile =
  | { kind: "decade"; decade: number }
  | { kind: "project"; project: Project };

const tiles: Tile[] = [];
let lastDecade: number | null = null;
for (const project of sorted) {
  const y = yearKey(project);
  const decade = y > 0 ? Math.floor(y / 10) * 10 : null;
  if (decade !== null && decade !== lastDecade) {
    tiles.push({ kind: "decade", decade });
    lastDecade = decade;
  }
  tiles.push({ kind: "project", project });
}
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="pt-[4.5rem] px-5 sm:pt-24">
      <div class="grid grid-cols-2 gap-5 sm:grid-cols-3 lg:grid-cols-4">
        {tiles.map((tile) => {
          if (tile.kind === "decade") {
            return (
              <div class="aspect-square flex items-center justify-center select-none" aria-hidden="true">
                <span class="font-serif text-muted text-4xl sm:text-5xl lg:text-6xl leading-none">{tile.decade}s</span>
              </div>
            );
          }
          const { project } = tile;
          const cover = project.data.images[0];
          const coverSrc = cover ? `/thumbnails/${project.slug}.jpg` : null;
          const fullImageSrc = cover ? `/projects/${project.slug}/${cover.url}.jpg` : null;
          return (
            <a id={project.slug} class="group relative overflow-hidden cursor-pointer aspect-square bg-white block" href={`/projects/${project.slug}/`} data-full-image={fullImageSrc}>
              {coverSrc && (
                <img
                  src={coverSrc}
                  alt={project.data.title}
                  loading="eager"
                  transition:name={`project-${project.slug}`}
                  class="w-full h-full object-contain block transition-[transform,opacity] duration-500 group-hover:scale-[1.04] group-hover:opacity-[0.88]"
                />
              )}
              <div class="absolute inset-0 flex flex-col justify-end p-4 bg-gradient-to-t from-black/45 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                <span class="text-xs font-medium text-white tracking-[0.06em] uppercase">{project.data.title}</span>
              </div>
            </a>
          );
        })}
      </div>
    </main>
    <script>
      document.addEventListener('astro:after-swap', () => {
        if (window.location.pathname !== '/') return;
        const hash = window.location.hash.slice(1);
        const slug = hash || sessionStorage.getItem('lastProjectSlug');
        sessionStorage.removeItem('lastProjectSlug');
        if (!slug) return;
        const el = document.getElementById(slug);
        if (el) el.scrollIntoView({ block: 'center', behavior: 'instant' });
      });
    </script>
  </body>
</html>
