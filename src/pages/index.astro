---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="pt-[4.5rem] px-5 sm:pt-24">
      <div class="grid grid-cols-2 gap-5 sm:grid-cols-3 lg:grid-cols-4">
        {projects.map((project) => {
          const cover = project.data.images[0];
          const coverSrc = cover ? `/thumbnails/${project.slug}.jpg` : null;
          return (
            <a class="group relative overflow-hidden cursor-pointer aspect-square bg-white block" href={`/projects/${project.slug}/`}>
              {coverSrc && (
                <img
                  src={coverSrc}
                  alt={project.data.title}
                  loading="eager"
                  transition:name={`project-${project.slug}`}
                  class="w-full h-full object-cover block transition-[transform,opacity] duration-500 group-hover:scale-[1.04] group-hover:opacity-[0.88]"
                />
              )}
              <div class="absolute inset-0 flex flex-col justify-end p-4 bg-gradient-to-t from-black/45 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                <span class="text-xs font-medium text-white tracking-[0.06em] uppercase">{project.data.title}</span>
              </div>
            </a>
          );
        })}
      </div>
    </main>
  </body>
</html>
