---
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

const allProjects = await getCollection("projects");
type Project = typeof allProjects[number];
const yearKey = (p: Project) =>
  Number(p.data.year?.match(/\d{4}/g)?.pop() ?? 0);
const sorted = allProjects.sort((a, b) => yearKey(b) - yearKey(a));

type Tile =
  | { kind: "decade"; decade: number }
  | { kind: "project"; project: Project };

const tiles: Tile[] = [];
let lastDecade: number | null = null;
for (const project of sorted) {
  const y = yearKey(project);
  const decade = y > 0 ? Math.floor(y / 10) * 10 : null;
  if (decade !== null && decade !== lastDecade) {
    tiles.push({ kind: "decade", decade });
    lastDecade = decade;
  }
  tiles.push({ kind: "project", project });
}
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="pt-[4.5rem] px-5 sm:pt-24">
      <div class="grid grid-cols-2 gap-5 sm:grid-cols-3 lg:grid-cols-4 stagger-in">
        {tiles.map((tile, i) => {
          if (tile.kind === "decade") {
            return (
              <div class="aspect-square flex items-center justify-center select-none" style={`--i:${i}`} aria-hidden="true">
                <span class="font-display font-bold text-muted text-4xl sm:text-5xl lg:text-6xl leading-none">{tile.decade}s</span>
              </div>
            );
          }
          const { project } = tile;
          const cover = project.data.images[0];
          const coverSrc = cover ? `/thumbnails/${project.slug}.jpg` : null;
          const fullImageSrc = cover ? `/projects/${project.slug}/${cover.url}.jpg` : null;
          return (
            <a id={project.slug} class="group relative overflow-hidden cursor-pointer aspect-square bg-white block" style={`--i:${i}`} href={`/projects/${project.slug}/`} data-full-image={fullImageSrc}>
              {coverSrc && (
                <img
                  src={coverSrc}
                  alt={project.data.title}
                  loading="eager"
                  transition:name={`project-${project.slug}`}
                  class="w-full h-full object-contain block tile-img group-hover:opacity-[0.88]"
                />
              )}
              <div class="absolute inset-0 flex flex-col justify-end p-4 bg-gradient-to-t from-black/45 to-transparent opacity-0 transition-opacity duration-700 group-hover:opacity-100">
                <span class="text-xs font-medium text-white tracking-[0.06em] uppercase">{project.data.title}</span>
              </div>
            </a>
          );
        })}
      </div>
    </main>
    <style>
      .tile-img {
        transition: opacity 700ms;
      }
      @keyframes tile-in {
        from { opacity: 0; transform: translateY(10px); }
        to   { opacity: 1; transform: none; }
      }
      .stagger-in > * {
        animation: tile-in 480ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
        animation-delay: calc(var(--i, 0) * 28ms);
      }
      @keyframes quick-fade-in {
        from { opacity: 0; }
        to   { opacity: 1; }
      }
      .fade-in-quick > * {
        animation: quick-fade-in 300ms ease-out both;
      }
      @media (prefers-reduced-motion: reduce) {
        .stagger-in > *,
        .fade-in-quick > * { animation: none; }
      }
    </style>
    <script>
      document.addEventListener('astro:after-swap', () => {
        if (window.location.pathname !== '/') return;
        const hash = window.location.hash.slice(1);
        const slug = hash || sessionStorage.getItem('lastProjectSlug');
        sessionStorage.removeItem('lastProjectSlug');
        if (!slug) return;
        const el = document.getElementById(slug);
        if (el) el.scrollIntoView({ block: 'center', behavior: 'instant' });
      });
    </script>
  </body>
</html>
