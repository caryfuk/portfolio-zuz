---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import { SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Price — ${SITE_TITLE}`} description="Interior design services and pricing." />
  </head>
  <body>
    <Header />
    <main class="px-5 pt-20 pb-[3.25rem] min-h-screen sm:px-6 sm:pt-[5.625rem] sm:pb-[3.75rem] lg:px-10 lg:pt-24 lg:pb-20">
      <div class="max-w-xl mx-auto mt-8">
        <span class="block text-[0.8125rem] tracking-[0.1em] uppercase text-muted mb-5">Price</span>
        <p class="text-sm text-muted mb-12 leading-[1.8]">All projects are quoted individually based on scope and complexity. The rates below are indicative. Get in touch to discuss your project.</p>
        <table class="w-full border-collapse text-sm">
          <tr class="border-t border-b border-line">
            <td class="py-[1.125rem] align-top">
              <div class="font-medium text-sm">Consultation</div>
              <div class="text-xs text-muted mt-1">1–2 hour session, on location or remote</div>
            </td>
            <td class="py-[1.125rem] align-top text-right text-muted whitespace-nowrap">from €150</td>
          </tr>
          <tr class="border-b border-line">
            <td class="py-[1.125rem] align-top">
              <div class="font-medium text-sm">Interior Design</div>
              <div class="text-xs text-muted mt-1">Concept, drawings, material board</div>
            </td>
            <td class="py-[1.125rem] align-top text-right text-muted whitespace-nowrap">from €2,500</td>
          </tr>
          <tr class="border-b border-line">
            <td class="py-[1.125rem] align-top">
              <div class="font-medium text-sm">Renovation Guidance</div>
              <div class="text-xs text-muted mt-1">Full follow-up from design to execution</div>
            </td>
            <td class="py-[1.125rem] align-top text-right text-muted whitespace-nowrap">on request</td>
          </tr>
          <tr class="border-b border-line">
            <td class="py-[1.125rem] align-top">
              <div class="font-medium text-sm">Custom Furniture</div>
              <div class="text-xs text-muted mt-1">Design + production coordination</div>
            </td>
            <td class="py-[1.125rem] align-top text-right text-muted whitespace-nowrap">on request</td>
          </tr>
        </table>
      </div>
    </main>
  </body>
</html>
