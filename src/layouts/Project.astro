---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";

type ContentComponent = Awaited<ReturnType<CollectionEntry<"projects">["render"]>>["Content"];

type Props = CollectionEntry<"projects"> & {
  Content: ContentComponent;
  prevSlug: string;
  prevImageCount: number;
  nextSlug: string;
  firstImageAR?: number;
};

const {
  slug,
  data,
  Content,
  prevSlug,
  prevImageCount,
  nextSlug,
  firstImageAR = 1,
} = Astro.props as Props;
const { title, images, year, location, credits, category } = data;

const categoryLabels = category.map((c) =>
  c.replace(/-/g, " ").replace(/^./, (ch) => ch.toUpperCase())
);

const imageUrls = images.map((img) => `/projects/${slug}/${img.url}.jpg`);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`${title} — Zuzi Knaze`}
      description={[title, location, year].filter(Boolean).join(', ')}
      image={imageUrls[0]}
      imageAlt={title}
    />
  </head>
  <body class="lg:overflow-hidden">
    <Header />
    <div class="flex flex-col pt-[4.5rem] sm:pt-[5.625rem] lg:flex-row lg:h-screen">
      <div class="relative flex-none overflow-hidden bg-white cursor-pointer h-[70vw] min-h-64 sm:h-[55vw] sm:min-h-72 lg:flex-1 lg:h-[calc(100vh-5.625rem)] lg:min-h-0 flex items-center justify-center">
        <img id="viewer-img" src={imageUrls[0]} alt={title} transition:name={`project-${slug}`} style={`aspect-ratio: ${firstImageAR}`} class="w-full h-full object-contain block" />
        <div class="absolute top-0 left-0 w-1/2 h-full z-[2] cursor-pointer" id="click-prev"></div>
        <div class="absolute top-0 right-0 w-1/2 h-full z-[2] cursor-pointer" id="click-next"></div>
      </div>
      <div class="flex-none px-5 py-6 flex flex-col lg:overflow-y-auto sm:px-6 sm:py-7 lg:flex-none lg:w-[40%] xl:w-[30%] lg:py-10 lg:px-12">
        <div class="flex-1 flex flex-col justify-center w-full lg:max-w-[32rem] lg:mx-auto">
          <a href={`/#${slug}`} class="inline-flex items-center gap-2 text-[0.8125rem] tracking-[0.1em] uppercase text-muted mb-5 transition-opacity duration-200 hover:opacity-60">
            <span>←</span>
            <span>Projects</span>
          </a>
          <h2 class="text-xl font-normal mb-3.5 leading-[1.25] sm:text-2xl">{title}</h2>
          <div class="mb-[1.125rem]">
            {year && <p class="text-[0.8125rem] text-muted leading-[1.9]">{year}</p>}
            {location && (
              <button
                type="button"
                id="open-map-btn"
                class="block text-left text-[0.8125rem] text-muted leading-[1.9] bg-transparent border-0 p-0 cursor-pointer transition-colors duration-200 hover:text-black underline decoration-dotted underline-offset-4"
              >
                {location}
              </button>
            )}
            {categoryLabels.length > 0 && <p class="text-[0.8125rem] text-muted leading-[1.9]">{categoryLabels.join(", ")}</p>}
          </div>
          <div class="text-sm leading-[1.85] text-prose mb-5"><Content /></div>
          {credits && <p class="text-xs text-muted leading-[2]">{credits}</p>}
        </div>
        <div transition:persist="project-nav" class="flex items-center justify-between pt-2 w-full lg:max-w-[32rem] lg:mx-auto">
          <button class="bg-transparent border-0 font-sans text-[0.8125rem] text-muted tracking-[0.06em] uppercase cursor-pointer transition-colors duration-200 hover:text-black p-0" id="btn-prev">← previous</button>
          <span class="text-[0.8125rem] text-muted tracking-[0.04em]" id="viewer-counter">1 / {imageUrls.length}</span>
          <button class="bg-transparent border-0 font-sans text-[0.8125rem] text-muted tracking-[0.06em] uppercase cursor-pointer transition-colors duration-200 hover:text-black p-0" id="btn-next">next →</button>
        </div>
      </div>
    </div>

    {location && (
      <dialog id="map-dialog" class="p-0 m-auto rounded-sm border-0 w-[90vw] h-[70vh] max-w-4xl max-h-[640px] backdrop:bg-black/50">
        <div class="relative w-full h-full bg-white">
          <button type="button" id="close-map-btn" aria-label="Close map" class="absolute top-2 right-2 z-10 w-8 h-8 rounded-full bg-white/95 border border-black/10 cursor-pointer text-lg leading-none hover:bg-white">×</button>
          <iframe id="map-iframe" class="w-full h-full border-0 block" title={`Map of ${location}`} loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
      </dialog>
    )}

    <script is:inline define:vars={{ imageUrls, title, prevSlug, prevImageCount, nextSlug, mapQuery: location }}>
      history.scrollRestoration = 'manual';

      document.addEventListener('astro:page-load', () => {
        requestAnimationFrame(() => window.scrollTo(0, 0));
      }, { once: true });

      const params = new URLSearchParams(window.location.search);
      const startIndex = Math.min(parseInt(params.get('start') || '0', 10), imageUrls.length - 1);

      let current = isNaN(startIndex) ? 0 : startIndex;
      const img = document.getElementById('viewer-img');
      const counter = document.getElementById('viewer-counter');
      const total = imageUrls.length;
      let isAnimating = false;
      let touchStartX = 0;
      let touchStartY = 0;

      function updateCounter() {
        counter.textContent = `${current + 1} / ${total}`;
      }

      function goTo(index) {
        if (isAnimating || index < 0 || index >= total) return;
        isAnimating = true;
        img.style.opacity = '0';
        setTimeout(() => {
          current = index;
          img.src = imageUrls[current];
          img.onload = () => { img.style.aspectRatio = `${img.naturalWidth} / ${img.naturalHeight}`; img.style.opacity = '1'; isAnimating = false; };
          img.onerror = () => { img.style.opacity = '1'; isAnimating = false; };
          updateCounter();
        }, 300);
      }

      function next() {
        if (current < total - 1) {
          goTo(current + 1);
        } else {
          window.location.href = `/projects/${nextSlug}`;
        }
      }

      function prev() {
        if (current > 0) {
          goTo(current - 1);
        } else {
          window.location.href = `/projects/${prevSlug}?start=${prevImageCount - 1}`;
        }
      }

      document.getElementById('click-next').addEventListener('click', next);
      document.getElementById('click-prev').addEventListener('click', prev);
      document.getElementById('btn-next').addEventListener('click', next);
      document.getElementById('btn-prev').addEventListener('click', prev);

      document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowRight') next();
        else if (e.key === 'ArrowLeft') prev();
      });

      document.addEventListener('touchstart', (e) => {
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
      }, { passive: true });

      document.addEventListener('touchend', (e) => {
        const dx = e.changedTouches[0].clientX - touchStartX;
        const dy = e.changedTouches[0].clientY - touchStartY;
        if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy) * 1.5) {
          if (dx < 0) next(); else prev();
        }
      }, { passive: true });

      img.style.transition = 'opacity .35s ease';
      updateCounter();

      if (mapQuery) {
        const mapBtn = document.getElementById('open-map-btn');
        const mapDialog = document.getElementById('map-dialog');
        const mapIframe = document.getElementById('map-iframe');
        const closeBtn = document.getElementById('close-map-btn');
        if (mapBtn && mapDialog && mapIframe && closeBtn) {
          mapBtn.addEventListener('click', () => {
            mapIframe.src = `https://maps.google.com/maps?q=${encodeURIComponent(mapQuery)}&output=embed`;
            mapDialog.showModal();
          });
          closeBtn.addEventListener('click', () => mapDialog.close());
          mapDialog.addEventListener('close', () => { mapIframe.src = 'about:blank'; });
          mapDialog.addEventListener('click', (e) => {
            if (e.target === mapDialog) mapDialog.close();
          });
        }
      }
    </script>
  </body>
</html>
