---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';

type ContentComponent = Awaited<ReturnType<CollectionEntry<'projects'>['render']>>['Content'];

type Props = CollectionEntry<'projects'> & {
  Content: ContentComponent;
  prevSlug: string;
  prevImageCount: number;
  nextSlug: string;
};

const { slug, data, Content, prevSlug, prevImageCount, nextSlug } = Astro.props as Props;
const { title, images, year, location, credits, isViz } = data;

const imageUrls = images.map(img => `/projects/${slug}/${img.url}.jpg`);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`${title} — Zuzi Knaze`}
      description={[title, location, year].filter(Boolean).join(', ')}
      image={imageUrls[0]}
      imageAlt={title}
    />
  </head>
  <body class="lg:overflow-hidden">
    <Header />
    <div class="flex flex-col pt-[4.5rem] sm:pt-[5.625rem] lg:flex-row lg:h-screen">
      <div class="relative flex-none overflow-hidden bg-white cursor-pointer h-[70vw] min-h-64 sm:h-[55vw] sm:min-h-72 lg:flex-[1.4] lg:h-[calc(100vh-5.625rem)] lg:min-h-0">
        <img id="viewer-img" src={`/thumbnails/${slug}.jpg`} alt={title} transition:name={`project-${slug}`} class="w-full h-full object-cover block" />
        <div class="absolute top-0 left-0 w-1/2 h-full z-[2] cursor-pointer" id="click-prev"></div>
        <div class="absolute top-0 right-0 w-1/2 h-full z-[2] cursor-pointer" id="click-next"></div>
      </div>
      <div class="flex-none px-5 py-6 flex flex-col overflow-y-auto sm:px-6 sm:py-7 lg:flex-1 lg:py-10 lg:px-12">
        <div class="flex-1 flex flex-col justify-center">
          <a href="/" class="inline-flex items-center gap-2 text-[0.8125rem] tracking-[0.1em] uppercase text-muted mb-5 transition-opacity duration-200 hover:opacity-60">
            <span>←</span>
            <span>Projects</span>
          </a>
          <h2 class="font-serif text-xl font-normal mb-3.5 leading-[1.25] sm:text-2xl">{title}</h2>
          <div class="mb-[1.125rem]">
            {year && <p class="text-[0.8125rem] text-muted leading-[1.9]">{year}</p>}
            {location && <p class="text-[0.8125rem] text-muted leading-[1.9]">{location}</p>}
            {isViz && <p class="text-xs text-faint italic mt-1">Visualisation / concept</p>}
          </div>
          <div class="text-sm leading-[1.85] text-prose mb-5"><Content /></div>
          {credits && <p class="text-xs text-muted leading-[2]">{credits}</p>}
        </div>
        <div transition:persist="project-nav" class="flex items-center justify-between pt-6">
          <button class="bg-transparent border-0 font-sans text-xs text-muted tracking-[0.06em] uppercase cursor-pointer transition-colors duration-200 hover:text-black p-0" id="btn-prev">← previous</button>
          <span class="text-xs text-muted tracking-[0.04em]" id="viewer-counter">1 / {imageUrls.length}</span>
          <button class="bg-transparent border-0 font-sans text-xs text-muted tracking-[0.06em] uppercase cursor-pointer transition-colors duration-200 hover:text-black p-0" id="btn-next">next →</button>
        </div>
      </div>
    </div>

    <script is:inline define:vars={{ imageUrls, title, prevSlug, prevImageCount, nextSlug }}>
      const params = new URLSearchParams(window.location.search);
      const startIndex = Math.min(parseInt(params.get('start') || '0', 10), imageUrls.length - 1);

      let current = isNaN(startIndex) ? 0 : startIndex;
      const img = document.getElementById('viewer-img');
      const counter = document.getElementById('viewer-counter');
      const total = imageUrls.length;
      let isAnimating = false;
      let initialSwapPending = true;
      let touchStartX = 0;

      function updateCounter() {
        counter.textContent = `${current + 1} / ${total}`;
      }

      function goTo(index) {
        if (isAnimating || index < 0 || index >= total) return;
        initialSwapPending = false;
        isAnimating = true;
        img.style.opacity = '0';
        setTimeout(() => {
          current = index;
          img.src = imageUrls[current];
          img.onload = () => { img.style.opacity = '1'; isAnimating = false; };
          img.onerror = () => { img.style.opacity = '1'; isAnimating = false; };
          updateCounter();
        }, 300);
      }

      function next() {
        if (current < total - 1) {
          goTo(current + 1);
        } else {
          window.location.href = `/projects/${nextSlug}`;
        }
      }

      function prev() {
        if (current > 0) {
          goTo(current - 1);
        } else {
          window.location.href = `/projects/${prevSlug}?start=${prevImageCount - 1}`;
        }
      }

      document.getElementById('click-next').addEventListener('click', next);
      document.getElementById('click-prev').addEventListener('click', prev);
      document.getElementById('btn-next').addEventListener('click', next);
      document.getElementById('btn-prev').addEventListener('click', prev);

      document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowRight') next();
        else if (e.key === 'ArrowLeft') prev();
      });

      document.addEventListener('touchstart', (e) => {
        touchStartX = e.touches[0].clientX;
      }, { passive: true });

      document.addEventListener('touchend', (e) => {
        const dx = e.changedTouches[0].clientX - touchStartX;
        if (Math.abs(dx) > 40) { if (dx < 0) next(); else prev(); }
      }, { passive: true });

      img.style.transition = 'opacity .35s ease';
      updateCounter();

      // img.src starts as the thumbnail (same URL the list uses), so the
      // view-transition is a pixel-perfect match with no flash. Once the
      // full-res image is ready, swap it in silently.
      const startUrl = imageUrls[current];
      if (startUrl) {
        const hi = new Image();
        hi.src = startUrl;
        hi.onload = () => {
          if (initialSwapPending) {
            initialSwapPending = false;
            img.src = startUrl;
          }
        };
      }
    </script>
  </body>
</html>
